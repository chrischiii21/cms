---
import type { StatItem } from '../utils/emdash';

interface Props {
  stats: StatItem[];
}

const { stats } = Astro.props;
---

<section class="border-y border-charcoal-600/30 bg-charcoal-900/60 backdrop-blur-sm relative z-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-charcoal-600/20 py-8 text-center">
      {stats.map((stat, index) => (
        <div class={`flex flex-col justify-center py-6 md:py-4 px-4 ${index >= 2 ? 'pt-8 md:pt-4' : ''}`}>
          <span class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-charcoal-100 font-sans">
            {stat.stat_number}
          </span>
          <span class="mt-2 text-xs font-bold uppercase tracking-wider text-charcoal-400">
            {stat.stat_label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
