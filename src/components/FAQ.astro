---
import type { FAQItem } from '../utils/emdash';

interface Props {
  faqs: FAQItem[];
}

const { faqs } = Astro.props;
---

<section id="faq" class="py-24 sm:py-32 bg-charcoal-900 border-t border-charcoal-600/30 scroll-mt-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="text-xs font-bold uppercase tracking-[0.25em] text-gold-accent">Common Inquiries</span>
      <h2 class="mt-4 text-3xl sm:text-4xl lg:text-5xl font-serif tracking-tight text-charcoal-100 uppercase">
        Frequently Asked Questions
      </h2>
      <div class="mt-4 w-12 h-1 bg-gold-accent mx-auto"></div>
    </div>

    <!-- Accordion Grid -->
    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="group border border-charcoal-600/25 bg-charcoal-800/30 rounded-lg overflow-hidden transition-all duration-300 hover:border-gold-accent/30">
          <summary class="flex justify-between items-center p-6 text-left cursor-pointer select-none font-bold text-base sm:text-lg text-charcoal-100 hover:bg-charcoal-800/40 transition-colors duration-200">
            <span class="pr-6 uppercase tracking-wide leading-snug">{faq.question}</span>
            <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full border border-charcoal-600/40 text-charcoal-400 group-hover:text-gold-accent group-hover:border-gold-accent/40 transition-all duration-300">
              <svg class="h-4 w-4 transform group-open:rotate-180 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6 pt-2 border-t border-charcoal-600/10 text-charcoal-400 font-light leading-relaxed text-sm sm:text-base bg-charcoal-900/20">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
