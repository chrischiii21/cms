---
import type { TargetAudience } from '../utils/emdash';

interface Props {
  data: TargetAudience;
}

const { data } = Astro.props;
---

<section id="audience" class="py-24 sm:py-32 bg-charcoal-950 scroll-mt-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 sm:mb-20">
      <span class="text-xs font-bold uppercase tracking-[0.25em] text-gold-accent">Buyer Suitability</span>
      <h2 class="mt-4 text-4xl sm:text-5xl font-serif tracking-tight text-charcoal-100 uppercase">
        Target Audience
      </h2>
      <p class="mt-4 text-charcoal-400 font-light max-w-xl">
        We operate an exclusive transaction desk. We only interface with principals who match our execution capabilities and respect our underwriting integrity.
      </p>
      <div class="mt-4 w-12 h-1 bg-gold-accent"></div>
    </div>

    <!-- Comparison Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Do's Card (Who we work with) -->
      <div class="relative overflow-hidden rounded-lg border border-gold-accent/20 bg-charcoal-900 p-8 sm:p-10 shadow-xl transition-all duration-300 hover:border-gold-accent/40">
        <div class="absolute top-0 left-0 w-1.5 h-full bg-gold-accent"></div>
        
        <div class="flex items-center gap-4 mb-8">
          <div class="inline-flex items-center justify-center rounded bg-gold-accent/10 p-2 text-gold-accent">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-2xl font-serif font-bold uppercase tracking-tight text-charcoal-100">
            Who I Work With
          </h3>
        </div>

        <ul class="space-y-6">
          {data.dos.map(doItem => (
            <li class="flex items-start gap-4">
              <svg class="mt-1 h-5 w-5 text-gold-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-charcoal-300 font-light leading-relaxed text-sm sm:text-base">
                {doItem}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Don'ts Card (What we don't do) -->
      <div class="relative overflow-hidden rounded-lg border border-charcoal-700 bg-charcoal-900 p-8 sm:p-10 shadow-xl transition-all duration-300 hover:border-charcoal-600">
        <div class="absolute top-0 left-0 w-1.5 h-full bg-charcoal-600"></div>

        <div class="flex items-center gap-4 mb-8">
          <div class="inline-flex items-center justify-center rounded bg-charcoal-800 p-2 text-charcoal-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </div>
          <h3 class="text-2xl font-serif font-bold uppercase tracking-tight text-charcoal-100">
            What I Don't Do
          </h3>
        </div>

        <ul class="space-y-6">
          {data.donts.map(dontItem => (
            <li class="flex items-start gap-4 opacity-80">
              <svg class="mt-1 h-5 w-5 text-charcoal-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-charcoal-400 font-light leading-relaxed text-sm sm:text-base">
                {dontItem}
              </span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>
