---
import type { ServiceItem } from '../utils/emdash';

interface Props {
  services: ServiceItem[];
}

const { services } = Astro.props;

// Map icon strings to simple, premium SVG drawings
const getIconSvg = (iconName?: string) => {
  switch (iconName) {
    case 'underwriting':
      return `<svg class="h-6 w-6 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5M18 16.5h2.25A2.25 2.25 0 0022.5 14.25V3M18.75 16.5V19.5m0-3h-3.75M15 19.5l3.75-3m0 0L15 13.5M6.75 6h10.5m-10.5 3h10.5m-10.5 3h6" />
      </svg>`;
    case 'sourcing':
      return `<svg class="h-6 w-6 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m0 15v2.25m-9.75-9.75h2.25m15 0h2.25m-12.728-5.303l1.591 1.591m12.274 12.274l1.591 1.591M6.136 17.864l1.591-1.591m12.274-12.274l1.591-1.591" />
      </svg>`;
    case 'alignment':
      return `<svg class="h-6 w-6 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM3 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 019.374 21c-2.331 0-4.512-.645-6.374-1.766z" />
      </svg>`;
    case 'execution':
      return `<svg class="h-6 w-6 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751A11.959 11.959 0 0112 2.714z" />
      </svg>`;
    default:
      return `<svg class="h-6 w-6 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>`;
  }
};
---

<section id="approach" class="py-24 sm:py-32 bg-charcoal-950 scroll-mt-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 sm:mb-20">
      <span class="text-xs font-bold uppercase tracking-[0.25em] text-gold-accent">Dispositions Process</span>
      <h2 class="mt-4 text-4xl sm:text-5xl font-serif tracking-tight text-charcoal-100 uppercase">
        My Approach
      </h2>
      <div class="mt-4 w-12 h-1 bg-gold-accent"></div>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, index) => {
        // Map bento grid layout positions:
        // Card 1: lg:col-span-1
        // Card 2: lg:col-span-2
        // Card 3: lg:col-span-2
        // Card 4: lg:col-span-1
        let gridSpanClass = "col-span-1";
        if (index === 1 || index === 2) {
          gridSpanClass = "col-span-1 md:col-span-2 lg:col-span-2";
        } else {
          gridSpanClass = "col-span-1 md:col-span-1 lg:col-span-1";
        }

        return (
          <div class={`bento-card flex flex-col justify-between min-h-[300px] group ${gridSpanClass}`}>
            <div>
              <!-- Icon Container -->
              <div class="inline-flex items-center justify-center rounded-lg bg-charcoal-700/60 p-3.5 border border-charcoal-600/30 group-hover:border-gold-accent/30 group-hover:bg-charcoal-700 transition-all duration-300">
                <Fragment set:html={getIconSvg(service.icon)} />
              </div>

              <!-- Content -->
              <h3 class="mt-6 text-xl sm:text-2xl font-serif font-bold text-charcoal-100 tracking-tight leading-snug uppercase group-hover:text-gold-accent transition-colors duration-300">
                {service.title}
              </h3>
              
              <p class="mt-4 text-sm sm:text-base text-charcoal-400 font-light leading-relaxed">
                {service.description}
              </p>
            </div>

            <!-- Indicator link icon -->
            <div class="mt-8 flex items-center justify-end">
              <span class="text-xs font-bold uppercase tracking-widest text-charcoal-400 group-hover:text-gold-accent transition-colors duration-300 flex items-center gap-1.5">
                0{index + 1}
                <svg class="h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
