---
import type { InvestmentDiscipline } from '../utils/emdash';

interface Props {
  data: InvestmentDiscipline;
}

const { data } = Astro.props;
---

<section id="discipline" class="py-24 sm:py-32 bg-charcoal-900 border-y border-charcoal-600/30 scroll-mt-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 sm:mb-20">
      <span class="text-xs font-bold uppercase tracking-[0.25em] text-gold-accent">Execution Standards</span>
      <h2 class="mt-4 text-4xl sm:text-5xl font-serif tracking-tight text-charcoal-100 uppercase">
        {data.section_title}
      </h2>
      <div class="mt-4 w-12 h-1 bg-gold-accent"></div>
    </div>

    <!-- Principles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16">
      {data.principles.map((principle, index) => (
        <div class="flex gap-6 group">
          <!-- Big index number -->
          <div class="text-4xl sm:text-5xl font-extrabold font-mono text-charcoal-600 group-hover:text-gold-accent transition-colors duration-300 select-none">
            {(index + 1).toString().padStart(2, '0')}
          </div>
          
          <!-- Content -->
          <div class="flex-grow">
            <h3 class="text-xl sm:text-2xl font-serif font-bold uppercase text-charcoal-100 tracking-tight">
              {principle.title}
            </h3>
            <div class="mt-2 w-8 h-[2px] bg-charcoal-600 group-hover:bg-gold-accent transition-colors duration-300"></div>
            <p class="mt-4 text-sm sm:text-base text-charcoal-400 font-light leading-relaxed">
              {principle.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
