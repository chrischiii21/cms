---
import type { FooterSection } from '../utils/emdash';

interface Props {
  data: FooterSection;
}

const { data } = Astro.props;
---

<section id="contact" class="bg-charcoal-950 border-t border-charcoal-600/30 scroll-mt-20">
  <!-- Final CTA Form Section -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start">
      
      <!-- Copy column -->
      <div class="lg:col-span-5 max-w-xl">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-gold-accent">Acquisitions Portal</span>
        <h2 class="mt-4 text-3xl sm:text-4xl font-serif text-charcoal-100 leading-tight uppercase">
          Secure Priority Placement
        </h2>
        <p class="mt-6 text-sm sm:text-base text-charcoal-400 font-light leading-relaxed">
          Due to the deeply discounted nature and compressed timelines of our inventory, deals are allocated on a first-come, first-served basis to verified buyers. 
        </p>
        <p class="mt-4 text-sm sm:text-base text-charcoal-400 font-light leading-relaxed">
          Submit your requirements to receive targeted off-market listings matching your buy-box coordinates.
        </p>

        <!-- Contact details -->
        <div class="mt-8 space-y-4 border-t border-charcoal-600/20 pt-8">
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a href={`mailto:${data.contact_info.email}`} class="text-sm font-semibold text-charcoal-300 hover:text-gold-accent transition-colors duration-200">
              {data.contact_info.email}
            </a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.802-5.14-4.118-6.944-6.94l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <a href={`tel:${data.contact_info.phone}`} class="text-sm font-semibold text-charcoal-300 hover:text-gold-accent transition-colors duration-200">
              {data.contact_info.phone}
            </a>
          </div>
          <div class="flex items-start gap-3">
            <svg class="h-5 w-5 text-gold-accent mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="text-sm text-charcoal-400 font-light">
              {data.contact_info.address}
            </span>
          </div>
        </div>
      </div>

      <!-- Form column -->
      <div class="lg:col-span-7 bg-charcoal-900 border border-charcoal-600/30 p-8 sm:p-10 rounded-lg shadow-xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-gold-accent to-transparent"></div>
        
        <form class="space-y-6" onsubmit="event.preventDefault(); alert('Acquisitions desk notified. A representative will contact you to verify proof of funds.');">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="first-name" class="block text-xs font-bold uppercase tracking-wider text-charcoal-400">First Name</label>
              <input 
                type="text" 
                id="first-name" 
                required 
                class="mt-2 block w-full rounded border border-charcoal-600/40 bg-charcoal-950 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-500 focus:border-gold-accent focus:outline-none focus:ring-1 focus:ring-gold-accent transition-colors duration-200" 
                placeholder="John" 
              />
            </div>
            <div>
              <label for="last-name" class="block text-xs font-bold uppercase tracking-wider text-charcoal-400">Last Name</label>
              <input 
                type="text" 
                id="last-name" 
                required 
                class="mt-2 block w-full rounded border border-charcoal-600/40 bg-charcoal-950 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-500 focus:border-gold-accent focus:outline-none focus:ring-1 focus:ring-gold-accent transition-colors duration-200" 
                placeholder="Doe" 
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-xs font-bold uppercase tracking-wider text-charcoal-400">Email Address</label>
              <input 
                type="email" 
                id="email" 
                required 
                class="mt-2 block w-full rounded border border-charcoal-600/40 bg-charcoal-950 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-500 focus:border-gold-accent focus:outline-none focus:ring-1 focus:ring-gold-accent transition-colors duration-200" 
                placeholder="johndoe@email.com" 
              />
            </div>
            <div>
              <label for="phone" class="block text-xs font-bold uppercase tracking-wider text-charcoal-400">Phone Number</label>
              <input 
                type="tel" 
                id="phone" 
                required 
                class="mt-2 block w-full rounded border border-charcoal-600/40 bg-charcoal-950 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-500 focus:border-gold-accent focus:outline-none focus:ring-1 focus:ring-gold-accent transition-colors duration-200" 
                placeholder="(555) 000-0000" 
              />
            </div>
          </div>

          <div>
            <label for="buybox" class="block text-xs font-bold uppercase tracking-wider text-charcoal-400">Primary Buy-Box Parameters</label>
            <textarea 
              id="buybox" 
              rows="3" 
              required 
              class="mt-2 block w-full rounded border border-charcoal-600/40 bg-charcoal-950 px-4 py-3 text-sm text-charcoal-100 placeholder-charcoal-500 focus:border-gold-accent focus:outline-none focus:ring-1 focus:ring-gold-accent transition-colors duration-200 resize-none" 
              placeholder="e.g. SFR redevelopments in Los Angeles County, rehab budget $100k-$250k, target margins >20%..."
            ></textarea>
          </div>

          <div class="flex items-start">
            <div class="flex h-5 items-center">
              <input 
                id="pof" 
                name="pof" 
                type="checkbox" 
                required 
                class="h-4 w-4 rounded border-charcoal-600/60 bg-charcoal-950 text-gold-accent focus:ring-gold-accent focus:ring-offset-charcoal-900 focus:ring-2" 
              />
            </div>
            <div class="ml-3 text-xs">
              <label for="pof" class="font-bold text-charcoal-300 uppercase tracking-wide">I have liquid capital / active line of credit</label>
              <p class="text-charcoal-400 font-light mt-1">I certify that I can purchase assets all-cash and close transactions within 14 days without financing contingencies.</p>
            </div>
          </div>

          <button 
            type="submit" 
            class="w-full text-center px-6 py-4 bg-gold-accent hover:bg-gold-accent-hover text-charcoal-950 font-bold uppercase text-xs tracking-widest rounded transition-all duration-300 hover:shadow-lg hover:shadow-gold-accent/20"
          >
            Submit Underwriting Request
          </button>
        </form>
      </div>

    </div>
  </div>

  <!-- Real Legal Footer -->
  <div class="bg-charcoal-950 border-t border-charcoal-600/20 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center border-b border-charcoal-600/10 pb-8">
        
        <!-- Branding logo -->
        <div class="flex flex-col font-extrabold tracking-widest text-lg leading-tight">
          <span class="text-charcoal-100">CHRISCHIII</span>
          <span class="text-xs text-gold-accent font-medium tracking-[0.25em]">DISPOSITIONS</span>
        </div>

        <!-- Links -->
        <div class="flex flex-wrap gap-x-8 gap-y-2 text-xs font-bold uppercase tracking-wider text-charcoal-400 justify-start md:justify-end">
          <a href="#approach" class="hover:text-charcoal-100 transition-colors duration-200">Approach</a>
          <a href="#discipline" class="hover:text-charcoal-100 transition-colors duration-200">Discipline</a>
          <a href="#audience" class="hover:text-charcoal-100 transition-colors duration-200">Target Audience</a>
          <a href="#schedule" class="hover:text-charcoal-100 transition-colors duration-200">Schedule</a>
          <a href="#faq" class="hover:text-charcoal-100 transition-colors duration-200">FAQ</a>
        </div>

      </div>

      <!-- Legal copy & Disclaimers -->
      <div class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <p class="lg:col-span-7 text-xs text-charcoal-400 leading-relaxed font-light">
          {data.legal_disclaimers}
        </p>
        <p class="lg:col-span-5 text-xs text-charcoal-400 font-light lg:text-right">
          {data.footer_text}
        </p>
      </div>
    </div>
  </div>
</section>
