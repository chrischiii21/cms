          // Toast show helper
          function showToast(message: string, isError = false) {
            const toast = document.getElementById('toast-notification');
            if (!toast) return;
            const titleEl = document.getElementById('toast-title');
            const descEl = document.getElementById('toast-desc');
            const iconEl = document.getElementById('toast-icon');
            
            if (titleEl) titleEl.innerText = isError ? 'Error Saving Changes' : 'Content Saved';
            if (descEl) descEl.innerText = message;
            
            if (iconEl) {
              if (isError) {
                iconEl.innerText = '✕';
                iconEl.className = 'w-6 h-6 rounded-full bg-red-600 flex items-center justify-center text-white font-bold text-sm';
                toast.style.borderColor = '#ef4444';
              } else {
                iconEl.innerText = '✓';
                iconEl.className = 'w-6 h-6 rounded-full bg-[#A88254] flex items-center justify-center text-charcoal-100 font-bold text-sm';
                toast.style.borderColor = '#A88254';
              }
            }
            
            toast.classList.remove('translate-y-10', 'opacity-0', 'pointer-events-none');
            toast.classList.add('translate-y-0', 'opacity-100');
            
            setTimeout(() => {
              toast.classList.add('translate-y-10', 'opacity-0', 'pointer-events-none');
              toast.classList.remove('translate-y-0', 'opacity-100');
            }, 7000);
          }

          try {
            const response = await fetch('/api/content/landing-page', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(payload)
            });

            if (response.ok) {
              showToast('The local JSON database and site have successfully rebuilt.', false);
              setTimeout(() => {
                window.location.reload();
              }, 6500);
            } else {
              const err = await response.json();
              showToast(err.error || 'Server error occurred.', true);
            }
          } catch (e: any) {
            showToast(e.message || 'Connection failed.', true);
          } finally {
            saveBtn.innerText = "Save Changes";
            saveBtn.disabled = false;
          }
        });
      }
    </script>
    <!-- Toast Notification -->
    <div 
      id="toast-notification" 
      class="fixed bottom-5 right-5 z-50 flex items-center gap-3 px-5 py-4 bg-[#1C1814] border border-gold-accent text-white rounded-lg shadow-2xl transform translate-y-10 opacity-0 pointer-events-none transition-all duration-500 ease-out"
    >
      <div id="toast-icon" class="w-6 h-6 rounded-full bg-gold-accent flex items-center justify-center text-charcoal-100 font-bold text-sm">✓</div>
      <div class="flex flex-col">
        <span id="toast-title" class="text-xs font-bold uppercase tracking-wider text-white">Content Saved</span>
        <span id="toast-desc" class="text-[10px] text-gray-300 font-light mt-0.5">The local JSON database and site have successfully rebuilt.</span>
      </div>
    </div>
  </body>
</html>
