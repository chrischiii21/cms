            ],
            approach: [
              {
                title: formData.get('approach_title_0'),
                description: formData.get('approach_desc_0'),
                icon: formData.get('approach_icon_0')
              },
              {
                title: formData.get('approach_title_1'),
                description: formData.get('approach_desc_1'),
                icon: formData.get('approach_icon_1')
              },
              {
                title: formData.get('approach_title_2'),
                description: formData.get('approach_desc_2'),
                icon: formData.get('approach_icon_2')
              },
              {
                title: formData.get('approach_title_3'),
                description: formData.get('approach_desc_3'),
                icon: formData.get('approach_icon_3')
              }
            ],
            discipline: {
              section_title: formData.get('discipline_title'),
              principles: [
                { title: formData.get('discipline_principle_title_0'), description: formData.get('discipline_principle_desc_0') },
                { title: formData.get('discipline_principle_title_1'), description: formData.get('discipline_principle_desc_1') },
                { title: formData.get('discipline_principle_title_2'), description: formData.get('discipline_principle_desc_2') },
                { title: formData.get('discipline_principle_title_3'), description: formData.get('discipline_principle_desc_3') }
              ]
            },
            audience: {
              dos: (formData.get('audience_dos') as string).split('\n').map(item => item.trim()).filter(item => item !== ''),
              donts: (formData.get('audience_donts') as string).split('\n').map(item => item.trim()).filter(item => item !== '')
            },
            schedule: {
